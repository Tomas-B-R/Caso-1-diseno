ASPNETCORE_ENVIRONMENT=Development
Api__BasePath=/api/v1
Api__AllowedOrigins__0=https://localhost:5173
Authentication__Authority=https://login.microsoftonline.com/<tenant-id>/v2.0
Authentication__Audience=api://dua-streamliner-api
Authentication__RequireHttpsMetadata=true
Processing__MaxUploadSizeMb=50
Processing__AcceptedContentTypes__0=application/pdf
Processing__AcceptedContentTypes__1=application/vnd.openxmlformats-officedocument.wordprocessingml.document
Processing__AcceptedContentTypes__2=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
Processing__AcceptedContentTypes__3=image/png
Processing__AcceptedContentTypes__4=image/jpeg
Storage__ConnectionString=UseDevelopmentStorage=true
Storage__DocumentsContainer=dua-documents
Storage__GeneratedContainer=dua-generated
SqlDatabase__ConnectionString=Server=tcp:dua-streamliner-dev.database.windows.net,1433;Initial Catalog=duastreamliner;Persist Security Info=False;
NotificationHub__ConnectionString=Endpoint=sb://dua-notifications.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;
NotificationHub__HubName=dua-streamliner
Observability__ApplicationInsightsConnectionString=InstrumentationKey=<instrumentation-key>
KeyVault__VaultUri=https://dua-streamliner-kv.vault.azure.net/
AiInterpretation__Endpoint=https://ai-processing.internal/
AiInterpretation__ApiVersion=2024-10-21
Retention__SourceFileDays=30
Retention__GeneratedDuaDays=180
Retention__AuditLogDays=365
