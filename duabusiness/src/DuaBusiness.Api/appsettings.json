{
  "Api": {
    "BasePath": "/api/v1",
    "AllowedOrigins": [
      "https://localhost:5173"
    ]
  },
  "Authentication": {
    "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
    "Audience": "api://dua-streamliner-api",
    "RequireHttpsMetadata": true,
    "RateLimitPerMinute": 120
  },
  "Processing": {
    "MaxUploadSizeMb": 50,
    "MaxRetryAttempts": 3,
    "AcceptedContentTypes": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "image/png",
      "image/jpeg"
    ]
  },
  "Storage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "DocumentsContainer": "dua-documents",
    "GeneratedContainer": "dua-generated"
  },
  "SqlDatabase": {
    "ConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=DuaBusiness;Trusted_Connection=True;"
  },
  "NotificationHub": {
    "ConnectionString": "Endpoint=sb://dua-notification-hub.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;",
    "HubName": "dua-status"
  },
  "Observability": {
    "ApplicationInsightsConnectionString": "",
    "EnableTracing": true
  },
  "KeyVault": {
    "VaultUri": "https://dua-streamliner-kv.vault.azure.net/"
  },
  "AiInterpretation": {
    "Endpoint": "https://semantic-interpreter.internal/",
    "ApiVersion": "2024-10-21",
    "ModelName": "gpt-4o-mini"
  },
  "Retention": {
    "SourceFileDays": 30,
    "GeneratedDuaDays": 180,
    "AuditLogDays": 365
  }
}
